# KBID Proposal Generator — environment (copy to backend/.env, never commit .env)

# --- app ---
APP_ENV=dev                 # dev | prod
PORT=8902
FRONTEND_DIR=../frontend    # relative to backend/ (or absolute)

# --- database (self-hosted Postgres in a Docker container) ---
# local dev default matches docker-compose (service: kbid-db)
DATABASE_URL=postgresql://kbid:kbid_dev_pw@127.0.0.1:5438/kbid

# --- auth: Clerk (managed) ---
# from the Clerk dashboard for the KBID instance
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# JWKS/issuer are derived from the publishable key's Frontend API host if left blank
CLERK_ISSUER=
CLERK_JWKS_URL=
# comma-separated allowlist of emails permitted to use the tool
AUTH_ALLOWLIST=designer@example.com,admin@example.com
# admins (can manage users); subset of the allowlist
AUTH_ADMINS=admin@example.com

# DEV ONLY: skip Clerk locally so the UI/estimate can be smoke-tested without keys.
# MUST be 0/false in prod. When 1, requests are treated as a fake dev admin.
DEV_AUTH_BYPASS=1

# --- claude narrative / autofill (uses the logged-in Claude CLI, no API key) ---
CLAUDE_BIN=claude
CLAUDE_MODEL=sonnet
